{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Validate config with Ajv",
      "type": "npm",
      "script": "validate:config",
      "group": "test",
      "problemMatcher": {
        "owner": "ajv",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(error|warning):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    }
  ]
}
