{
    "$schema": "../dynstyle.schema.json",
    "title": "Capitals",
    "scales": [0, 10000000],
    "cacheKey": "capitals",
    "static": {
        "capital": {
            "zIndex": 30,
            "image": {
                "type": "Circle",
                "radius": 3.5,
                "fill": {
                    "color": "rgba(220, 38, 38, 0.95)"
                },
                "stroke": {
                    "color": "#ffffff",
                    "width": 1.25
                }
            },
            "text": {
                "step": "map",
                "declutter": "first",
                "text": "",
                "font": "11px sans-serif",
                "offsetY": -12,
                "fill": {
                    "color": "#7f1d1d"
                },
                "stroke": {
                    "color": "rgba(255, 255, 255, 0.92)",
                    "width": 3
                },
                "padding": [2, 3, 2, 3]
            }
        }
    },
    "dynamic": [
        {
            "pointer": "#/capital/text/text",
            "value": "=> F.properties?.city ?? F.properties?.country ?? ''"
        }
    ]
}
