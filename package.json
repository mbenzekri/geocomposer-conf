{
  "name": "geo-composer",
  "private": true,
  "scripts": {
    "validate:json": "node -e \"JSON.parse(require('node:fs').readFileSync('config.json', 'utf8'))\"",
    "validate:config": "node scripts/validate-config.mjs",
    "build" : "docker compose build server",
    "run" : "docker compose run --rm --service-ports server",
    "up" : "docker compose up -d server",
    "down" : "docker compose down  server",
    "rm" : "npm run down; docker compose rm  server"
  },
  "devDependencies": {
    "ajv": "^8.17.1"
  }
}
