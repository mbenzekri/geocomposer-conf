{
  "name": "geo-composer-config",
  "version": "1.0.0",
  "private": true,
  "description": "Configuration repository for Geo Composer",
  "license": "UNLICENSED",
  "config": {
    "geocVersion": "v1.0.0",
    "geocReleaseUrl": "https://github.com/<organisation>/geo-composer/releases/download"
  },
  "scripts": {
    "postinstall": "curl -fsSL \"$npm_package_config_geocReleaseUrl/$npm_package_config_geocVersion/config.schema.json\" -o config.schema.json && curl -fsSL \"$npm_package_config_geocReleaseUrl/$npm_package_config_geocVersion/style.schema.json\" -o style.schema.json"
  }
}
